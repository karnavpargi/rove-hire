# =============================================================================
# ROVE Hire — Environment Variables
# Copy to .env and adjust values before running Docker Compose.
# =============================================================================

# PostgreSQL
POSTGRES_USER=rove_user
POSTGRES_PASSWORD=rove_password
POSTGRES_DB=rove_hire
DB_PORT=5432

# Application ports (host → container)
API_PORT=3000
WEB_PORT=3001

# Runtime
NODE_ENV=production
JWT_SECRET=change-me-in-production

# Public URLs (browser-facing; used for CORS, cookies, and Next.js build args)
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/graphql

# HTTPS production (set when serving over TLS)
COOKIE_SECURE=false
ENABLE_HSTS=false

# Database URL (host dev only — Docker Compose builds this from POSTGRES_* above)
DATABASE_URL=postgresql://rove_user:rove_password@localhost:5432/rove_hire?schema=public

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=rove-hire-files
