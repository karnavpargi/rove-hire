# =============================================================================
# ROVE Hire — Environment Variables
# Copy to .env and fill in actual values for development
# =============================================================================

# PostgreSQL
POSTGRES_USER=rove_user
POSTGRES_PASSWORD=rove_password
POSTGRES_DB=rove_hire
DB_PORT=5432

# API
API_PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Database URL (used by Prisma and the API)
DATABASE_URL=postgresql://rove_user:rove_password@localhost:5432/rove_hire?schema=public

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=rove-hire-files

# Frontend
FRONTEND_URL=http://localhost:3001
