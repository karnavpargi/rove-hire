{
  "Comment": "S3 bucket configuration for ROVE Hire file storage. All public access is blocked. Files are only accessible via pre-signed URLs generated by the FileService.",
  "PublicAccessBlockConfiguration": {
    "BlockPublicAcls": true,
    "IgnorePublicAcls": true,
    "BlockPublicPolicy": true,
    "RestrictPublicBuckets": true
  },
  "BucketPolicy": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "DenyPublicAccess",
        "Effect": "Deny",
        "Principal": "*",
        "Action": "s3:GetObject",
        "Resource": "arn:aws:s3:::${BUCKET_NAME}/*",
        "Condition": {
          "StringNotEquals": {
            "aws:PrincipalAccount": "${ACCOUNT_ID}"
          }
        }
      }
    ]
  }
}
