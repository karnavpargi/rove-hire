# =============================================================================
# ROVE Hire — Production deployment
# Copy to deploy/deploy.env and adjust secrets before first deploy.
# =============================================================================

# SSH target and install path (DietPi home directory)
DEPLOY_HOST=root@192.168.10.4
DEPLOY_PATH=/home/dietpi/rove-hire
DEPLOY_USER=dietpi
# Private key for passwordless SSH (optional; overrides sshpass when set)
SSH_IDENTITY_FILE=~/.ssh/rpi_Server_key.pem

# Public URL (HTTPS subdomain — web + GraphQL share this origin via host nginx)
APP_URL=https://rove.kpargi.eu.org

# Localhost ports for host nginx → Docker (change if these conflict)
API_HOST_PORT=13000
WEB_HOST_PORT=13001

# Host nginx paths (Debian / DietPi default layout)
NGINX_SITE_NAME=rove-hire
NGINX_SNIPPETS_DIR=/etc/nginx/snippets
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
# true = only install snippets; merge into your existing rove.kpargi.eu.org server block
NGINX_USE_EXISTING_SERVER=true

# PostgreSQL
POSTGRES_USER=rove_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=rove_hire

# API security
JWT_SECRET=change-me-long-random-secret

# HTTPS public site
COOKIE_SECURE=true
ENABLE_HSTS=true
NODE_ENV=production

# AWS S3 (required for resume upload / PDF download)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=rove-hire-files

# -----------------------------------------------------------------------------
# Container registry (pnpm docker:push + pnpm deploy:registry)
# Full cheat sheet: deploy/DEPLOY.md  |  pnpm deploy:help
# GHCR push requires: gh auth refresh -h github.com -s write:packages,read:packages
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=ghcr.io/your-github-username
IMAGE_TAG=latest
# Raspberry Pi / DietPi is arm64 — build on Mac M-series matches; Intel Mac uses buildx
DOCKER_PLATFORM=linux/arm64

API_IMAGE=${DOCKER_REGISTRY}/rove-hire-api:${IMAGE_TAG}
WEB_IMAGE=${DOCKER_REGISTRY}/rove-hire-web:${IMAGE_TAG}
DB_SETUP_IMAGE=${DOCKER_REGISTRY}/rove-hire-db-setup:${IMAGE_TAG}

# Optional: for private GHCR/Docker Hub (create PAT with read/write packages)
# DOCKER_REGISTRY_USER=your-github-username
# DOCKER_REGISTRY_TOKEN=ghp_...
